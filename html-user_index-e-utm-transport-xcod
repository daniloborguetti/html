<script>
(function() {
  var processedForms = new WeakSet();
  var protectedLeadUserIndex = null;

  function isAdminPage() {
    try {
      var url = window.location.href.toLowerCase();
      var pathname = window.location.pathname.toLowerCase();

      var adminPatterns = [
        '/wp-admin','/wp-login','wp-admin/','wp-login.php','/admin','/administrator','/backend','/panel','/dashboard',
        'action=elementor','elementor-preview','elementor_library',
        'et_fb=1','et_bfb=1','fb-edit=1',
        'builder=true','builder=visual','ct_builder=true','bricks=run',
        'brizy-edit','brizy-edit-iframe',
        'tve=true','vc_action=','fl_builder',
        'page_id=','preview=true','preview_id=','customize_changeset_uuid','/customize.php',
        'cornerstone=1','cs-render=1','ct_render=1',
        'oxy_user_role','oxygen_iframe=true',
        'zion_builder','is_frame=true'
      ];

      for (var i = 0; i < adminPatterns.length; i++) {
        if (url.indexOf(adminPatterns[i]) > -1 || pathname.indexOf(adminPatterns[i]) > -1) return true;
      }

      if (window.elementorFrontend && window.elementorFrontend.isEditMode && window.elementorFrontend.isEditMode()) return true;
      if (window.elementor) return true;
      if (window.ETBuilderBackend) return true;
      if (window.FLBuilder) return true;
      if (window.vc_iframe) return true;
      if (window.Cornerstone) return true;
      if (window.CTFrontendBuilder) return true;

      if (document.body && document.body.classList) {
        var adminClasses = [
          'elementor-editor-active','et-fb','et-bfb','fl-builder-edit','vc_editor','brizy-editor','tve_editor_page',
          'ct-builder','bricks-is-frontend','oxygen-builder-body','zion-builder-active','wp-admin','wp-customizer'
        ];

        for (var j = 0; j < adminClasses.length; j++) {
          if (document.body.classList.contains(adminClasses[j])) return true;
        }
      }

      if (document.querySelector('.elementor-editor-active, .et-fb, .fl-builder-edit, .vc_editor, .brizy-editor, .ct-builder, .bricks-is-frontend, .oxygen-builder-body')) {
        return true;
      }

      return false;
    } catch (e) {
      return false;
    }
  }

  if (isAdminPage()) return;

  function getIndex() { return Date.now().toString(); }

  function getRootDomain(hostname) {
    try {
      var parts = hostname.split('.');
      if (parts.length >= 3) {
        var tld = parts.slice(-2).join('.');
        var compoundTLDs = ['com.br','org.br','net.br','gov.br','co.uk','com.au'];
        for (var i = 0; i < compoundTLDs.length; i++) {
          if (compoundTLDs[i] === tld) return parts.slice(-3).join('.');
        }
      }
      return parts.slice(-2).join('.');
    } catch (e) { return hostname; }
  }

  function setCookie(name, value) {
    try {
      var domain = getRootDomain(window.location.hostname);
      var cookieDomain = "." + domain;
      var expires = new Date(new Date().getTime() + 365 * 24 * 60 * 1000).toUTCString();
      document.cookie = name + "=" + value +
                        "; SameSite=None; Secure" +
                        "; expires=" + expires +
                        "; path=/; domain=" + cookieDomain;
    } catch (e) {}
  }

  function getCookie(name) {
    try {
      var value = "; " + document.cookie;
      var parts = value.split("; " + name + "=");
      if (parts.length === 2) return parts.pop().split(";").shift();
    } catch (e) {}
    return null;
  }

  function setLeadUserIndex(value) {
    try {
      window.LeadUserIndex = value;
      protectedLeadUserIndex = value;
      sessionStorage.setItem('LeadUserIndex', value);
      localStorage.setItem('LeadUserIndex', value);
      setCookie('LeadUserIndex', value);
    } catch (e) {}
  }

  function getLeadUserIndex() {
    try {
      if (window.LeadUserIndex) return window.LeadUserIndex;
      var sessionValue = sessionStorage.getItem('LeadUserIndex'); if (sessionValue) return sessionValue;
      var localValue = localStorage.getItem('LeadUserIndex'); if (localValue) return localValue;
      var cookieValue = getCookie('LeadUserIndex'); if (cookieValue) return cookieValue;
    } catch (e) {}
    return null;
  }

  function getOrSetIndex() {
    try {
      var existingIndex = getLeadUserIndex();
      if (existingIndex) { setLeadUserIndex(existingIndex); return existingIndex; }
      var newIndex = getIndex();
      setLeadUserIndex(newIndex);
      return newIndex;
    } catch (e) { return getIndex(); }
  }

  function getCurrentUrlUtms() {
    try {
      var utms = {};
      var urlParams = new URLSearchParams(window.location.search);
      urlParams.forEach(function(value, key) { if (key.indexOf('utm_') === 0) utms[key] = value; });
      return utms;
    } catch (e) { return {}; }
  }

  function saveUtmsToSession() {
    try {
      var urlUtms = getCurrentUrlUtms();
      if (Object.keys(urlUtms).length > 0) sessionStorage.setItem('SessionUtms', JSON.stringify(urlUtms));
    } catch (e) {}
  }

  function getSessionUtms() {
    try {
      var sessionUtms = sessionStorage.getItem('SessionUtms');
      if (sessionUtms) return JSON.parse(sessionUtms);
    } catch (e) {}
    return {};
  }

  function extractExistingParams(url) {
    try {
      if (!url || typeof url !== 'string') return {};
      var existingParams = {};
      var questionMarkIndex = url.indexOf('?');
      if (questionMarkIndex === -1) return existingParams;

      var queryString = url.substring(questionMarkIndex + 1);
      var hashIndex = queryString.indexOf('#');
      if (hashIndex !== -1) queryString = queryString.substring(0, hashIndex);

      var pairs = queryString.split('&');
      for (var i = 0; i < pairs.length; i++) {
        if (pairs[i]) {
          var pair = pairs[i].split('=');
          var key = pair[0];
          var value = pair.length > 1 ? pair[1] : '';

          // mantém o indexador xcod como está (não duplica)
          if (key !== 'xcod') existingParams[key] = value;
        }
      }
      return existingParams;
    } catch (e) { return {}; }
  }

  function buildUrlWithXcod(index, existingParams) {
    try {
      var currentUrlUtms = getCurrentUrlUtms();
      var sessionUtms = getSessionUtms();
      var parts = ["xcod=" + index];

      var finalUtms = {};
      for (var key in sessionUtms) if (sessionUtms.hasOwnProperty(key)) finalUtms[key] = sessionUtms[key];
      for (var key2 in currentUrlUtms) if (currentUrlUtms.hasOwnProperty(key2)) finalUtms[key2] = currentUrlUtms[key2];

      for (var k in finalUtms) if (finalUtms.hasOwnProperty(k)) parts.push(k + "=" + finalUtms[k]);

      for (var eKey in existingParams) {
        if (existingParams.hasOwnProperty(eKey)) {
          var isUtm = eKey.indexOf('utm_') === 0;
          if (!isUtm) parts.push(eKey + "=" + existingParams[eKey]);
        }
      }

      return parts.length > 0 ? "?" + parts.join("&") : "";
    } catch (e) { return ""; }
  }

  function removeQueryString(url) {
    try {
      if (!url || typeof url !== 'string') return url;

      var questionMarkIndex = url.indexOf('?');
      var hashIndex = url.indexOf('#');

      if (questionMarkIndex === -1) return url;

      if (hashIndex !== -1) return url.substring(0, questionMarkIndex) + url.substring(hashIndex);
      return url.substring(0, questionMarkIndex);
    } catch (e) { return url; }
  }

  function hasXcodParam(url) {
    try { return !!(url && typeof url === 'string' && url.indexOf('xcod=') !== -1); }
    catch (e) { return false; }
  }

  function processRedirectUrl(url) {
    try {
      if (!url || typeof url !== 'string') return url;
      if (hasXcodParam(url)) return url;

      var index = getOrSetIndex();
      var existingParams = extractExistingParams(url);
      var baseUrl = removeQueryString(url);
      var urlString = buildUrlWithXcod(index, existingParams);

      return baseUrl + urlString;
    } catch (e) { return url; }
  }

  function scanObjectForRedirectUrl(obj, visited) {
    if (!visited) visited = new WeakSet();
    if (!obj || typeof obj !== 'object' || visited.has(obj)) return;

    visited.add(obj);

    try {
      if (obj.redirect_url && typeof obj.redirect_url === 'string') obj.redirect_url = processRedirectUrl(obj.redirect_url);

      for (var key in obj) {
        if (obj.hasOwnProperty(key)) {
          if (key === 'redirect_url' && typeof obj[key] === 'string') {
            obj[key] = processRedirectUrl(obj[key]);
          } else if (obj[key] && typeof obj[key] === 'object') {
            scanObjectForRedirectUrl(obj[key], visited);
          }
        }
      }
    } catch(e) {}
  }

  function isFormValid(form) {
    try {
      if (form.checkValidity && !form.checkValidity()) return false;

      var requiredFields = form.querySelectorAll('[required], [aria-required="true"], .elementor-field-required input, .elementor-field-required textarea, .elementor-field-required select');

      for (var i = 0; i < requiredFields.length; i++) {
        var field = requiredFields[i];
        if (field.offsetParent === null) continue;

        var value = field.value ? field.value.trim() : '';

        if (field.type === 'checkbox' || field.type === 'radio') {
          var name = field.name;
          var checked = form.querySelector('input[name="' + name + '"]:checked');
          if (!checked) return false;
        } else if (!value) {
          return false;
        }

        if (field.type === 'email' && value) {
          var emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
          if (!emailPattern.test(value)) return false;
        }
      }

      return true;
    } catch (e) { return true; }
  }

  function getFormData(form) {
    try {
      var formData = {};
      var elements = form.elements;

      for (var i = 0; i < elements.length; i++) {
        var element = elements[i];
        var name = element.name;
        var value = element.value;
        if (!name) continue;

        if (element.type === 'checkbox' || element.type === 'radio') {
          if (element.checked) {
            if (formData[name]) {
              if (Array.isArray(formData[name])) formData[name].push(value);
              else formData[name] = [formData[name], value];
            } else {
              formData[name] = value;
            }
          }
        } else if (element.type === 'select-multiple') {
          var selected = [];
          for (var j = 0; j < element.options.length; j++) if (element.options[j].selected) selected.push(element.options[j].value);
          formData[name] = selected;
        } else {
          formData[name] = value;
        }
      }

      return formData;
    } catch (e) { return {}; }
  }

  function pushFormSubmitEvent(form) {
    try {
      if (!isFormValid(form)) return;

      var formId = form.getAttribute('data-form-id') || form.id || '';
      var formName = form.getAttribute('name') || form.getAttribute('data-form-name') || '';
      var formClasses = form.className || '';
      var formAction = form.getAttribute('action') || window.location.href;
      var formData = getFormData(form);

      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: 'gtm.formSubmit',
        'gtm.element': form,
        'gtm.elementId': formId,
        'gtm.elementClasses': formClasses,
        'gtm.elementUrl': formAction,
        'form.id': formId,
        'form.name': formName,
        'form.action': formAction,
        'form.data': formData
      });
    } catch (e) {}
  }

  function processElementorForms(doc) {
    if (!doc) return;

    try {
      var forms = doc.querySelectorAll('.elementor-form, form[class*="elementor"]');

      for (var i = 0; i < forms.length; i++) {
        var form = forms[i];
        if (processedForms.has(form)) continue;

        try {
          processedForms.add(form);

          var dataSettings = form.getAttribute('data-settings');
          if (dataSettings) {
            try {
              var settings = JSON.parse(dataSettings);
              if (settings.redirect_url) {
                settings.redirect_url = processRedirectUrl(settings.redirect_url);
                form.setAttribute('data-settings', JSON.stringify(settings));
              }
            } catch (e) {}
          }

          form.addEventListener('submit', function() {
            try {
              pushFormSubmitEvent(this);

              var dataSettings = this.getAttribute('data-settings');
              if (dataSettings) {
                var settings = JSON.parse(dataSettings);
                if (settings.redirect_url) {
                  settings.redirect_url = processRedirectUrl(settings.redirect_url);
                  this.setAttribute('data-settings', JSON.stringify(settings));
                }
              }
            } catch (err) {}
          }, true);

        } catch (e) {}
      }
    } catch (e) {}
  }

  function interceptXHR() {
    try {
      var XHR = XMLHttpRequest.prototype;
      var send = XHR.send;

      XHR.send = function(data) {
        var self = this;
        var oldOnReadyStateChange = this.onreadystatechange;

        var processResponse = function() {
          if (self.readyState === 4) {
            try {
              var contentType = self.getResponseHeader('Content-Type') || '';
              if (contentType.indexOf('application/json') > -1 && self.responseText) {
                try {
                  var jsonData = JSON.parse(self.responseText);

                  if (jsonData && jsonData.data && jsonData.data.redirect_url) {
                    jsonData.data.redirect_url = processRedirectUrl(jsonData.data.redirect_url);
                    Object.defineProperty(self, 'responseText', { writable: true, configurable: true, value: JSON.stringify(jsonData) });
                  }
                } catch(parseError) {}
              }
            } catch(e) {}
          }
        };

        this.onreadystatechange = function() {
          processResponse();
          if (oldOnReadyStateChange) return oldOnReadyStateChange.apply(this, arguments);
        };

        return send.apply(this, arguments);
      };
    } catch(e) {}
  }

  function interceptFetch() {
    try {
      var originalFetch = window.fetch;
      window.fetch = function() {
        return originalFetch.apply(this, arguments).then(function(response) {
          var clonedResponse = response.clone();

          try {
            var contentType = response.headers.get('content-type') || '';
            if (contentType.indexOf('application/json') > -1) {
              clonedResponse.json().then(function(data) {
                try {
                  if (data && data.data && data.data.redirect_url) data.data.redirect_url = processRedirectUrl(data.data.redirect_url);
                } catch (e) {}
              }).catch(function() {});
            }
          } catch (e) {}

          return response;
        });
      };
    } catch (e) {}
  }

  function interceptElementorSubmit() {
    try {
      if (window.jQuery) {
        jQuery(document).on('submit_success', '.elementor-form', function(e, form) {
          try {
            if (form && form.settings && form.settings.redirect_url) form.settings.redirect_url = processRedirectUrl(form.settings.redirect_url);
            scanObjectForRedirectUrl(form);
          } catch (err) {}
        });
      }

      if (window.elementorFrontend && window.elementorFrontend.hooks) {
        window.elementorFrontend.hooks.addAction('frontend/element_ready/form.default', function($scope) {
          try { processElementorForms($scope[0] || document); } catch (e) {}
        });
      }
    } catch (e) {}
  }

  function observeDOMChanges() {
    try {
      if (window.MutationObserver) {
        var observer = new MutationObserver(function() {
          setTimeout(function() { processElementorForms(document); }, 500);
        });

        observer.observe(document.body || document.documentElement, { childList: true, subtree: true });
      }
    } catch (e) {}
  }

  try {
    saveUtmsToSession();
    getOrSetIndex();

    interceptXHR();
    interceptFetch();
    interceptElementorSubmit();

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() {
        setTimeout(function() {
          processElementorForms(document);
          observeDOMChanges();
        }, 500);
      });
    } else {
      setTimeout(function() {
        processElementorForms(document);
        observeDOMChanges();
      }, 500);
    }
  } catch (e) {}
})();
</script>
